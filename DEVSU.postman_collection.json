								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombres\": \"Marianela Montalvo\",\n    \"genero\": \"F\",\n    \"edad\": 25,\n    \"identificacion\": \"87654321\",\n    \"direccion\": \"Amazonas y NNUU\",\n    \"telefono\": \"097548965\",\n    \"estado\": 0,\n    \"password\": \"5678clave\"\n}"
						},
						"url": {
							"raw": "{{base_url_client}}/clientes",
							"host": ["{{base_url_client}}"],
