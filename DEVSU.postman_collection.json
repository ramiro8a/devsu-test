								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombres\": \"Jose Lema Actualizado\",\n    \"genero\": \"M\",\n    \"edad\": 31,\n    \"identificacion\": \"12345678\",\n    \"direccion\": \"Otavalo sn y principal - Piso 2\",\n    \"telefono\": \"098254785\",\n    \"estado\": 0,\n    \"password\": \"clave1234\"\n}"
