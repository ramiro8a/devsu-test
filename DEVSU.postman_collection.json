						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombres\": \"Jose Lema\",\n    \"genero\": \"M\",\n    \"edad\": 30,\n    \"identificacion\": \"12345678\",\n    \"direccion\": \"Otavalo sn y principal\",\n    \"telefono\": \"098254785\",\n    \"estado\": 0,\n    \"password\": \"clave1234\"\n}"
						},
						"url": {
							"raw": "{{base_url_client}}/clientes",
							"host": ["{{base_url_client}}"],
							"path": ["clientes"]
