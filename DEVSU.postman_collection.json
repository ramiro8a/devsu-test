					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url_account}}/cuentas/reportes?clientId=1&desde=2025-01-01&hasta=2026-12-31",
							"host": ["{{base_url_account}}"],
							"path": ["cuentas", "reportes"],
							"query": [
								{ "key": "clientId", "value": "1" },
								{ "key": "desde", "value": "2025-01-01" },
								{ "key": "hasta", "value": "2026-12-31" }
							]
						},
						"description": "Genera reporte de estado de cuenta por cliente y rango de fechas."
					},
					"response": []
